<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>VibeStream</title>
    <meta
      name="description"
      content="VibeStream — TV en direct, films et séries. Pages officielles support et confidentialité."
    />
    <link rel="stylesheet" href="assets/site.css" />
  </head>
  <body>
    <div class="wrap">
      <header>
        <div class="brand">
          <div class="brand-icon" aria-hidden="true">▶</div>
          <div>
            <h1>VibeStream</h1>
            <p class="sub">Votre univers TV</p>
          </div>
        </div>
        <nav class="links" aria-label="Navigation">
          <a href="support.html">Support</a>
          <a href="privacy.html">Confidentialité</a>
        </nav>
      </header>
      <main>
        <p>
          Site public des informations <strong>support</strong> et
          <strong>politique de confidentialité</strong> de l’application VibeStream
          (référencées sur l’App Store).
        </p>
        <div class="card">
          <p style="margin: 0">
            <a href="support.html">Page support →</a><br />
            <a href="privacy.html">Politique de confidentialité →</a>
          </p>
        </div>
        <p class="lang-note">
          <strong>EN</strong> — Support and privacy pages for the VibeStream app (linked from the App Store).
        </p>
      </main>
      <footer>
        <p>VibeStream · Pages hébergées sur GitHub Pages</p>
      </footer>
    </div>
  </body>
</html>
